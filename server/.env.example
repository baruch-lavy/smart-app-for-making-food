PORT=5030
MONGODB_URI=mongodb://localhost:27017/smart-cooking
JWT_SECRET=supersecretkey123

# ─── Recipe Search ──────────────────────────────────────────────────────────
# Get your FREE API key at https://spoonacular.com/food-api  (150 req/day free)
# When set → searches 360,000+ recipes from AllRecipes, Food Network, Epicurious,
#             Serious Eats, Tasty, and hundreds more websites.
# When not set → falls back to TheMealDB (~300 recipes, always free, no key needed)
SPOONACULAR_API_KEY=your_key_here
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
TAVILY_API_KEY=
SERPAPI_API_KEY=
AI_SEARCH_PROVIDER=auto
AI_IMAGE_PROVIDER=pollinations
AI_IMAGE_MODEL=flux
